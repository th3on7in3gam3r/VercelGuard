{
  "name": "vercelguard",
  "version": "0.1.0",
  "description": "Pre-deployment checker and error fixer for Vercel",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "vercelguard": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup && node scripts/add-shebang.js",
    "dev": "tsx src/index.ts",
    "check": "tsx src/index.ts check",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "execa": "^9.5.0",
    "fs-extra": "^11.3.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
